'use client';

import React, { useState, useMemo } from 'react';
import { Button } from '@/components/ui/button';
import { 
    Loader2,
    RefreshCw, 
    ChevronLeft, 
    ChevronRight, 
    ChevronDown, 
    ChevronUp, 
    Search,
    CheckCircle2,
    AlertCircle,
    Tag,
    ExternalLink,
    Code,
    Package,
    Layers,
    Fingerprint,
    Info,
    Check
} from 'lucide-react';
import {
    Table,
    TableBody,
    TableCell,
    TableHead,
    TableHeader,
    TableRow,
} from "@/components/ui/table";
import { Badge } from "@/components/ui/badge";
import { Input } from "@/components/ui/input";

interface ComponentRegistryItem {
    id: string;
    name: string;
    displayName: string;
    tier: string;
    category: string;
    tags: string[];
    usageCount: number;
    pages: string[];
    sourcePath: string;
    sourceImport: string;
    genesisStatus: string;
    genesisPath: string | null;
    genesisNotes: string | null;
    auditFlag: string;
    auditNotes: string | null;
    updatedAt: string;
}

export default function ComponentRegistryDashboard() {
    const [components, setComponents] = useState<ComponentRegistryItem[]>([]);
    const [loading, setLoading] = useState(true);
    const [page, setPage] = useState(1);
    const [searchTerm, setSearchTerm] = useState('');
    const [filterStatus, setFilterStatus] = useState<string>('ALL');
    const [expandedId, setExpandedId] = useState<string | null>(null);
    const ITEMS_PER_PAGE = 25;

    const fetchRegistry = async () => {
        setLoading(true);
        try {
            const res = await fetch('/api/swarm/registry');
            const data = await res.json();
            setComponents(Array.isArray(data) ? data : []);
        } catch (err) {
            console.error(err);
        } finally {
            setLoading(false);
        }
    };

    React.useEffect(() => {
        fetchRegistry();
    }, []);

    const filteredComponents = useMemo(() => {
        return components.filter(c => {
            const matchesSearch = c.name.toLowerCase().includes(searchTerm.toLowerCase()) || 
                                 c.category.toLowerCase().includes(searchTerm.toLowerCase());
            const matchesStatus = filterStatus === 'ALL' || c.genesisStatus === filterStatus;
            return matchesSearch && matchesStatus;
        });
    }, [components, searchTerm, filterStatus]);

    const totalPages = Math.ceil(filteredComponents.length / ITEMS_PER_PAGE);
    const paginatedComponents = filteredComponents.slice((page - 1) * ITEMS_PER_PAGE, page * ITEMS_PER_PAGE);

    const stats = useMemo(() => {
        return {
            total: components.length,
            exists: components.filter(c => c.genesisStatus === 'EXISTS').length,
            needsBuild: components.filter(c => c.genesisStatus === 'NEEDS_BUILD').length,
            clean: components.filter(c => c.auditFlag === 'CLEAN').length,
            flagged: components.filter(c => c.auditFlag !== 'CLEAN').length,
        };
    }, [components]);

    const getAuditColor = (flag: string) => {
        if (flag === 'CLEAN') return 'text-emerald-500';
        if (flag === 'PHANTOM' || flag === 'MALFORMED') return 'text-rose-500';
        return 'text-amber-500';
    };

    return (
        <div className="flex-1 overflow-y-auto p-4 md:p-8 max-w-[1600px] mx-auto w-full bg-background min-h-screen">
            <div className="flex flex-col gap-8">
                
                {/* Header Container */}
                <div className="flex flex-col md:flex-row md:items-end justify-between gap-6">
                    <div className="space-y-1">
                        <div className="flex items-center gap-3">
                            <div className="bg-primary/10 p-2 rounded-lg">
                                <Package className="size-6 text-primary" />
                            </div>
                            <h1 className="text-3xl font-extrabold tracking-tight">Component Registry</h1>
                        </div>
                        <p className="text-muted-foreground text-sm max-w-2xl">
                            The definitive inventory of 186 architectural components extracted from Metronic. 
                            Use this to track Genesis status, audit health, and implementation priorities.
                        </p>
                    </div>
                    
                    <div className="flex items-center gap-3">
                        <Button 
                            variant="outline" 
                            size="sm" 
                            onClick={fetchRegistry} 
                            disabled={loading}
                            className="h-10 px-4 font-semibold"
                        >
                            {loading ? <Loader2 className="size-4 animate-spin mr-2" /> : <RefreshCw className="size-4 mr-2" />}
                            Sync Registry
                        </Button>
                        <Button className="h-8 px-3 text-xs font-bold shadow-sm shadow-primary/20">
                            Build All (Sprint 1.2)
                        </Button>
                    </div>
                </div>

                {/* Stats Grid */}
                <div className="grid grid-cols-2 md:grid-cols-5 gap-4">
                    {[
                        { label: 'Total Components', value: stats.total, icon: Layers, color: 'text-foreground' },
                        { label: 'Genesis Ready', value: stats.exists, icon: CheckCircle2, color: 'text-emerald-500' },
                        { label: 'Missing (Sprint 1.2)', value: stats.needsBuild, icon: AlertCircle, color: 'text-rose-500' },
                        { label: 'Audit Passed', value: stats.clean, icon: Check, color: 'text-blue-500' },
                        { label: 'Audit Flagged', value: stats.flagged, icon: Info, color: 'text-amber-500' },
                    ].map((stat, i) => (
                        <div key={i} className="bg-muted/30 border rounded-xl p-4 flex flex-col gap-1 transition-all hover:bg-muted/50">
                            <div className="flex items-center justify-between">
                                <span className="text-[10px] font-bold uppercase tracking-wider text-muted-foreground">{stat.label}</span>
                                <stat.icon className={`size-4 ${stat.color}`} />
                            </div>
                            <span className="text-2xl font-black">{stat.value}</span>
                        </div>
                    ))}
                </div>

                {/* Filters & Actions */}
                <div className="flex flex-col md:flex-row gap-4 items-center">
                    <div className="relative flex-1 w-full">
                        <Search className="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-muted-foreground" />
                        <Input 
                            placeholder="Search by name, category, or tier..." 
                            className="pl-10 h-11 bg-muted/20 border-border/50 focus:bg-background transition-all"
                            value={searchTerm}
                            onChange={(e) => setSearchTerm(e.target.value)}
                        />
                    </div>
                    <div className="flex items-center gap-2 w-full md:w-auto">
                        <div className="flex bg-muted/50 p-1 rounded-lg border">
                            {['ALL', 'EXISTS', 'NEEDS_BUILD', 'UNKNOWN'].map((s) => (
                                <button
                                    key={s}
                                    onClick={() => setFilterStatus(s)}
                                    className={`px-3 py-1.5 text-[10px] font-bold rounded-md transition-all ${filterStatus === s ? 'bg-background shadow-sm text-primary' : 'text-muted-foreground hover:text-foreground'}`}
                                >
                                    {s}
                                </button>
                            ))}
                        </div>
                    </div>
                </div>

                {/* Main Table */}
                <div className="rounded-2xl border bg-background overflow-hidden shadow-sm">
                    <Table>
                        <TableHeader className="bg-muted/40">
                            <TableRow className="hover:bg-transparent border-b h-8">
                                <TableHead className="w-8 px-2"></TableHead>
                                <TableHead className="font-bold text-[10px] uppercase tracking-widest py-2 px-2">Component</TableHead>
                                <TableHead className="font-bold text-[10px] uppercase tracking-widest hidden md:table-cell py-2 px-2">Tier</TableHead>
                                <TableHead className="font-bold text-[10px] uppercase tracking-widest hidden lg:table-cell py-2 px-2">Category</TableHead>
                                <TableHead className="font-bold text-[10px] uppercase tracking-widest text-center py-2 px-2">Usage</TableHead>
                                <TableHead className="font-bold text-[10px] uppercase tracking-widest py-2 px-2">Genesis Status</TableHead>
                                <TableHead className="font-bold text-[10px] uppercase tracking-widest text-right pr-4 py-2">Health</TableHead>
                            </TableRow>
                        </TableHeader>
                        <TableBody>
                            {loading ? (
                                <TableRow>
                                    <TableCell colSpan={7} className="h-64 text-center">
                                        <div className="flex flex-col items-center justify-center gap-4 text-muted-foreground">
                                            <Loader2 className="size-8 animate-spin text-primary" />
                                            <span className="font-medium">Streaming components from registry...</span>
                                        </div>
                                    </TableCell>
                                </TableRow>
                            ) : paginatedComponents.length === 0 ? (
                                <TableRow>
                                    <TableCell colSpan={7} className="h-64 text-center text-muted-foreground">
                                        No components found matching your filters.
                                    </TableCell>
                                </TableRow>
                            ) : (
                                paginatedComponents.map((c) => (
                                    <React.Fragment key={c.id}>
                                        <TableRow 
                                            className={`group cursor-pointer transition-colors h-10 ${expandedId === c.id ? 'bg-muted/20' : 'hover:bg-muted/10'}`}
                                            onClick={() => setExpandedId(expandedId === c.id ? null : c.id)}
                                        >
                                            <TableCell className="px-2 py-1">
                                                {expandedId === c.id ? <ChevronUp className="size-3 text-primary" /> : <ChevronDown className="size-3 text-muted-foreground group-hover:text-foreground" />}
                                            </TableCell>
                                            <TableCell className="px-2 py-1">
                                                <div className="flex flex-col py-0.5">
                                                    <span className="font-bold text-xs text-foreground">{c.name}</span>
                                                    <span className="text-[9px] text-muted-foreground/60 font-mono tracking-tight leading-none">{c.displayName}</span>
                                                </div>
                                            </TableCell>
                                            <TableCell className="hidden md:table-cell px-2 py-1">
                                                <Badge variant="outline" className="font-mono text-[9px] px-1 h-4">{c.tier}</Badge>
                                            </TableCell>
                                            <TableCell className="hidden lg:table-cell px-2 py-1">
                                                <span className="text-[10px] font-medium text-muted-foreground">{c.category}</span>
                                            </TableCell>
                                            <TableCell className="text-center px-2 py-1">
                                                <span className="inline-flex items-center justify-center bg-muted px-1.5 py-0 rounded text-[9px] font-bold">
                                                    {c.usageCount}x
                                                </span>
                                            </TableCell>
                                            <TableCell className="px-2 py-1">
                                                <div className="flex items-center gap-1.5">
                                                    <div className={`size-1.5 rounded-full ${c.genesisStatus === 'EXISTS' ? 'bg-emerald-500' : c.genesisStatus === 'NEEDS_BUILD' ? 'bg-rose-500' : 'bg-muted-foreground/30'}`}></div>
                                                    <span className="text-[9px] font-bold uppercase tracking-wider leading-none">{c.genesisStatus.replace('_', ' ')}</span>
                                                </div>
                                            </TableCell>
                                            <TableCell className="text-right pr-4 py-1">
                                                <div className="flex items-center justify-end gap-1">
                                                    <span className={`text-[9px] font-black uppercase tracking-widest ${getAuditColor(c.auditFlag)}`}>
                                                        {c.auditFlag}
                                                    </span>
                                                    {c.auditFlag !== 'CLEAN' && <AlertCircle className={`size-2.5 ${getAuditColor(c.auditFlag)}`} />}
                                                </div>
                                            </TableCell>
                                        </TableRow>

                                        {expandedId === c.id && (
                                            <TableRow className="hover:bg-transparent">
                                                <TableCell colSpan={7} className="p-0 border-b bg-muted/5">
                                                    <div className="p-4 grid grid-cols-1 md:grid-cols-3 gap-6">
                                                        
                                                        {/* Source Info */}
                                                        <div className="space-y-4">
                                                            <div className="flex items-center gap-2 text-primary">
                                                                <Code className="size-4" />
                                                                <h4 className="text-xs font-black uppercase tracking-widest">Source Context</h4>
                                                            </div>
                                                            <div className="space-y-3">
                                                                <div>
                                                                    <label className="text-[10px] text-muted-foreground uppercase font-bold block mb-1">Source Path</label>
                                                                    <div className="bg-background border p-2 rounded text-[10px] font-mono break-all leading-relaxed shadow-sm">
                                                                        {c.sourcePath}
                                                                    </div>
                                                                </div>
                                                                <div>
                                                                    <label className="text-[10px] text-muted-foreground uppercase font-bold block mb-1">Import Statement</label>
                                                                    <div className="bg-background border p-2 rounded text-[10px] font-mono shadow-sm group relative">
                                                                        {c.sourceImport}
                                                                        <Button variant="ghost" size="icon" className="size-5 absolute right-1 top-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                                                            <Fingerprint className="size-3" />
                                                                        </Button>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        {/* Genesis Context */}
                                                        <div className="space-y-4">
                                                            <div className="flex items-center gap-2 text-emerald-500">
                                                                <CheckCircle2 className="size-4" />
                                                                <h4 className="text-xs font-black uppercase tracking-widest">Genesis Mapping</h4>
                                                            </div>
                                                            <div className="space-y-3">
                                                                <div>
                                                                    <label className="text-[10px] text-muted-foreground uppercase font-bold block mb-1">Target Path</label>
                                                                    <div className="bg-background border p-2 rounded text-[10px] font-mono shadow-sm italic text-muted-foreground/80">
                                                                        {c.genesisPath || 'Pending definition...'}
                                                                    </div>
                                                                </div>
                                                                <div>
                                                                    <label className="text-[10px] text-muted-foreground uppercase font-bold block mb-1">Implementation Notes</label>
                                                                    <div className="text-xs text-muted-foreground leading-relaxed leading-5">
                                                                        {c.genesisNotes || 'No specific technical constraints noted for this component.'}
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        {/* Metadata & Pages */}
                                                        <div className="space-y-4">
                                                            <div className="flex items-center gap-2 text-amber-500">
                                                                <Tag className="size-4" />
                                                                <h4 className="text-xs font-black uppercase tracking-widest">Metadata & Usage</h4>
                                                            </div>
                                                            <div className="space-y-3">
                                                                <div>
                                                                    <label className="text-[10px] text-muted-foreground uppercase font-bold block mb-1">Tags</label>
                                                                    <div className="flex flex-wrap gap-1.5">
                                                                        {c.tags.map(tag => (
                                                                            <Badge key={tag} variant="secondary" className="text-[9px] font-bold uppercase tracking-tighter px-1.5 rounded-sm">
                                                                                {tag}
                                                                            </Badge>
                                                                        ))}
                                                                    </div>
                                                                </div>
                                                                <div>
                                                                    <label className="text-[10px] text-muted-foreground uppercase font-bold block mb-2">Used In ({c.pages.length} Pages)</label>
                                                                    <div className="grid grid-cols-1 gap-1 max-h-32 overflow-y-auto pr-2 custom-scrollbar">
                                                                        {c.pages.map(page => (
                                                                            <a 
                                                                                key={page} 
                                                                                href={`http://localhost:3200${page}`}
                                                                                target="_blank"
                                                                                className="text-[10px] font-mono text-muted-foreground hover:text-primary flex items-center justify-between group/page"
                                                                            >
                                                                                {page}
                                                                                <ExternalLink className="size-2 opacity-0 group-hover/page:opacity-100" />
                                                                            </a>
                                                                        ))}
                                                                    </div>
                                                                </div>
                                                                {c.auditNotes && (
                                                                    <div>
                                                                        <label className="text-[10px] text-rose-500 uppercase font-black block mb-1 flex items-center gap-1">
                                                                            <Info className="size-2.5" /> Audit Feedback
                                                                        </label>
                                                                        <p className="text-[11px] text-foreground font-medium bg-rose-500/5 border border-rose-500/10 p-2 rounded">
                                                                            {c.auditNotes}
                                                                        </p>
                                                                    </div>
                                                                )}
                                                            </div>
                                                        </div>
                                                    </div>
                                                </TableCell>
                                            </TableRow>
                                        )}
                                    </React.Fragment>
                                ))
                            )}
                        </TableBody>
                    </Table>
                </div>

                {/* Pagination */}
                <div className="flex flex-col md:flex-row items-center justify-between gap-4 py-4">
                    <p className="text-xs font-bold text-muted-foreground uppercase tracking-widest">
                        Showing <span className="text-foreground">{paginatedComponents.length}</span> of <span className="text-foreground">{filteredComponents.length}</span> Results
                    </p>
                    <div className="flex items-center gap-2">
                        <Button
                            variant="outline"
                            size="sm"
                            disabled={page === 1}
                            onClick={() => setPage(page - 1)}
                            className="h-9 px-4 font-bold uppercase text-[10px] tracking-widest"
                        >
                            <ChevronLeft className="size-4 mr-2" />
                            Previous
                        </Button>
                        <div className="flex items-center gap-1">
                            {Array.from({ length: Math.min(5, totalPages) }, (_, i) => {
                                let pageNum = page;
                                if (page <= 3) pageNum = i + 1;
                                else if (page >= totalPages - 2) pageNum = totalPages - 4 + i;
                                else pageNum = page - 2 + i;
                                
                                if (pageNum > totalPages || pageNum < 1) return null;

                                return (
                                    <Button
                                        key={pageNum}
                                        variant={page === pageNum ? 'primary' : 'ghost'}
                                        size="sm"
                                        className="size-9 font-bold text-xs"
                                        onClick={() => setPage(pageNum)}
                                    >
                                        {pageNum}
                                    </Button>
                                );
                            })}
                        </div>
                        <Button
                            variant="outline"
                            size="sm"
                            disabled={page === totalPages}
                            onClick={() => setPage(page + 1)}
                            className="h-9 px-4 font-bold uppercase text-[10px] tracking-widest"
                        >
                            Next
                            <ChevronRight className="size-4 ml-2" />
                        </Button>
                    </div>
                </div>
            </div>

            <style jsx global>{`
                .custom-scrollbar::-webkit-scrollbar {
                    width: 4px;
                }
                .custom-scrollbar::-webkit-scrollbar-track {
                    background: transparent;
                }
                .custom-scrollbar::-webkit-scrollbar-thumb {
                    background: var(--border);
                    border-radius: 10px;
                }
            `}</style>
        </div>
    );
}
