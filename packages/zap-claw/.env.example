# ── OpenRouter ────────────────────────────────────────────
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model to use — any model available on OpenRouter.
# See https://openrouter.ai/models
# Examples:
#   anthropic/claude-opus-4-5
#   google/gemini-2.5-pro-preview
#   google/gemini-3-flash-preview
MODEL=anthropic/claude-opus-4-5

# ── Telegram ──────────────────────────────────────────────
# Get from @BotFather for each agent
TELEGRAM_BOT_TOKEN_CLAW=YOUR_CLAW_TOKEN_HERE
TELEGRAM_BOT_TOKEN_SPIKE=YOUR_SPIKE_TOKEN_HERE
TELEGRAM_BOT_TOKEN_THOMAS=YOUR_THOMAS_TOKEN_HERE
TELEGRAM_BOT_TOKEN_ATHENA=YOUR_ATHENA_TOKEN_HERE
TELEGRAM_BOT_TOKEN_HERMES=YOUR_HERMES_TOKEN_HERE
TELEGRAM_BOT_TOKEN_HAWK=YOUR_HAWK_TOKEN_HERE
TELEGRAM_BOT_TOKEN_NOVA=YOUR_NOVA_TOKEN_HERE
TELEGRAM_BOT_TOKEN_RAVEN=YOUR_RAVEN_TOKEN_HERE
TELEGRAM_BOT_TOKEN_SCOUT=YOUR_SCOUT_TOKEN_HERE

# ── OpenClaw Integration ──────────────────────────────────
OPENCLAW_WEBHOOK_URL=https://api.openclaw.com/v1/ata-ingress
OPENCLAW_AUTH_TOKEN=YOUR_AUTH_TOKEN

# ── Security ──────────────────────────────────────────────
# Comma-separated list of Telegram user IDs allowed to use the bot.
# Get your ID from https://t.me/userinfobot
ALLOWED_USER_IDS=234234324
# Comma-separated list of Telegram Group IDs for proactive monitoring (War Rooms).
WAR_ROOM_IDS=

# ── Brave Search ──
BRAVE_API_KEY=
