}

model ComponentRegistry {
  id String @id @default(uuid())

  // Identity
  name        String  @unique // e.g. "Button", "Toolbar", "UserHero"
  displayName String? // Human-friendly name, e.g. "User Hero Banner"

  // Classification
  tier     String // L3 (Atom), L4 (Molecule), L5 (Organism), L6 (Layout)
  category String // Navigation, Form, DataDisplay, Feedback, Layout, Surface, Content, Auth
  tags     String? // JSON array: ["shadcn", "metronic", "interactive", "form", "dashboard"]

  // Usage & Source
  usageCount   Int     @default(0) // How many Metronic pages use this
  pages        String? // JSON array of page URLs that use this component
  sourcePath   String? // Where it lives in Metronic source
  sourceImport String? // The import path (e.g., "@/components/ui/button")

  // Genesis Cross-Reference
  genesisStatus String  @default("UNKNOWN") // EXISTS, NEEDS_BUILD, NEEDS_IMPROVEMENT, NOT_NEEDED, UNKNOWN
  genesisPath   String? // Path to our Genesis component if it exists
  genesisNotes  String? // What's missing or needs improvement
  genesisOrigin String  @default("CORE") // CORE, METRO, SHARED, NEO, WIX

  // Audit
  auditFlag  String  @default("CLEAN") // CLEAN, PHANTOM, MISCLASSIFIED, DEMO, ICON, HTML, FRAMEWORK, DUPLICATE, PAGE_SECTION, MALFORMED
  auditNotes String? // Explanation of the flag

  // Metadata
  notes     String? // Free text notes
  createdAt DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updatedAt DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

model ZapPageAudit {
  id       String @id @default(uuid())
  pagePath String @unique
  theme    String @default("CORE") // "CORE" or "METRO"

  // ZAP Tier Compliance Ratings (e.g., 0-100 scale)
  l1TokensScore     Int? // Physics & Global Design Tokens
  l2PrimitivesScore Int? // Genesis Primitives & Atoms
  l3ElementsScore   Int? // Atomic UI components
  l4MoleculesScore  Int? // Localized logic components
  l5WidgetsScore    Int? // Complex data assemblies
  l6LayoutsScore    Int? // Structural containers / Shells
  l7PageScore       Int? // Full Route compliance

  // Overall Audit Status
  overallStatus String @default("PENDING") // PENDING, AI_REVIEWED, HUMAN_REVIEWED, APPROVED, REJECTED

  // AI Audit (Spike / Team Claud)
  aiAuditor     String? // Identifier for the agent (e.g., "Spike")
  aiReviewNotes String? // Detailed breakdown of non-compliance
  aiAuditedAt   DateTime?

  // Human Audit
  humanAuditor     String? // Name or ID of the human reviewer
  humanReviewNotes String?
  humanApprovedAt  DateTime?

  // Human Per-Level Ratings (0-100, overrides AI score)
  humanL1Rating      Int? // Physics & Global Design Tokens
  humanL2Rating      Int? // Genesis Primitives & Atoms
  humanL3Rating      Int? // Atomic UI components
  humanL4Rating      Int? // Localized logic components
  humanL5Rating      Int? // Complex data assemblies
  humanL6Rating      Int? // Structural containers / Shells
  humanL7Rating      Int? // Full Route compliance
  humanOverallRating Int? // Final human-assigned score

  createdAt DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updatedAt DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  @@index([theme])
  @@index([overallStatus])
}

model system_modules {
