// ── LEVEL 4: INVENTORY & BOM RECONCILIATION LEDGERS ─────────────────────────
// Enforcing Perpetual Inventory and BOM (Bill of Materials) equivalent to Toast/xtraCHEF

model raw_ingredients {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String  @db.Uuid
  name              String  @db.VarChar(255) // e.g., "Flour 50lb Bag", "Arabica Beans"
  sku               String? @db.VarChar(128)
  base_unit_measure String  @default("oz") @db.VarChar(32) // Fundamental tracking math (oz, lb, count)
  yield_percentage  Decimal @default(100.0) @db.Decimal(5, 2) // Subtracts waste/trim weight
  current_cost      Decimal @default(0) @db.Decimal(20, 8) // Dynamic calculation from AP Invoices

  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant               tenants                @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  bom_recipes          bom_recipes[]
  inventory_counts     inventory_counts[]
  inventory_movements  inventory_movements[]
  purchase_order_items purchase_order_items[]

  @@index([tenant_id], map: "idx_raw_ingredients_tenant_id")
}

model bom_recipes {
  id                 String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String @db.Uuid
  product_variant_id String @db.Uuid // The Finished Good being sold
  raw_ingredient_id  String @db.Uuid // The Raw Component being depleted

  quantity_needed Decimal @db.Decimal(10, 4) // e.g., 0.5 (lbs)
  unit_of_measure String  @db.VarChar(32) // Must structurally convert back to base_unit_measure

  tenant          tenants          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  product_variant product_variants @relation(fields: [product_variant_id], references: [id], onDelete: Cascade)
  raw_ingredient  raw_ingredients  @relation(fields: [raw_ingredient_id], references: [id], onDelete: Cascade)

  @@unique([product_variant_id, raw_ingredient_id], map: "idx_bom_recipes_unique_bridge")
  @@index([tenant_id], map: "idx_bom_recipes_tenant_id")
}

model inventory_counts {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String @db.Uuid
  raw_ingredient_id String @db.Uuid
  location_id       Int

  // THE STATE LEDGER
  quantity_on_hand Decimal  @default(0) @db.Decimal(15, 4) // Derived exclusively by summing inventory_movements
  quantity_warning Decimal? @db.Decimal(15, 4) // The PAR Level Threshold

  tenant         tenants         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  raw_ingredient raw_ingredients @relation(fields: [raw_ingredient_id], references: [id], onDelete: Cascade)
  location       locations       @relation(fields: [location_id], references: [id], onDelete: Cascade)

  @@unique([raw_ingredient_id, location_id], map: "idx_inv_counts_unique_loc")
  @@index([tenant_id], map: "idx_inv_counts_tenant_id")
}

model inventory_movements {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String @db.Uuid
  raw_ingredient_id String @db.Uuid
  location_id       Int

  // THE EVENT LEDGER
  adjustment_unit           Decimal @db.Decimal(15, 4) // Strict Double-Entry (+) or (-)
  movement_reason           String  @db.VarChar(64) // 'SALE', 'WASTE', 'RECEIPT', 'MANUAL_COUNT'
  reference_id              String? @db.VarChar(128) // Ties directly to the Order ID or Purchase Order ID
  purchase_order_id         String? @db.Uuid
  purchase_order_receipt_id String? @db.Uuid

  client_timestamp DateTime @default(now()) @db.Timestamptz(6) // Enforces sequence on offline tablets
  created_at       DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant                 tenants                  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  raw_ingredient         raw_ingredients          @relation(fields: [raw_ingredient_id], references: [id], onDelete: Cascade)
  location               locations                @relation(fields: [location_id], references: [id], onDelete: Cascade)
  purchase_order         purchase_orders?         @relation(fields: [purchase_order_id], references: [id], onDelete: SetNull)
  purchase_order_receipt purchase_order_receipts? @relation(fields: [purchase_order_receipt_id], references: [id], onDelete: SetNull)

  @@index([tenant_id], map: "idx_inv_movements_tenant_id")
  @@index([purchase_order_id], map: "idx_inv_movements_po_id")
  @@index([purchase_order_receipt_id], map: "idx_inv_movements_po_receipt_id")
  @@index([raw_ingredient_id, location_id], map: "idx_inv_movements_loc")
  @@index([client_timestamp], map: "idx_inv_movements_time_seq")
}

model vendors {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String   @db.Uuid
  name         String   @db.VarChar(255)
  contact_name String?  @db.VarChar(128)
  email        String?  @db.VarChar(255)
  phone        String?  @db.VarChar(32)
  address      Json     @default("{}")
  status       String   @default("active") @db.VarChar(32) // active, inactive
  created_at   DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at   DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant          tenants           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  purchase_orders purchase_orders[]

  @@index([tenant_id], map: "idx_vendors_tenant_id")
  @@index([status], map: "idx_vendors_status")
}

model purchase_orders {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  vendor_id    String    @db.Uuid
  location_id  Int // Where the goods are expected to land
  status       String    @default("draft") @db.VarChar(32) // draft, submitted, partial, completed, canceled
  total_amount Decimal   @default(0) @db.Decimal(20, 8)
  currency     String    @default("USD") @db.Char(3)
  expected_at  DateTime? @db.Timestamptz(6)
  notes        String?
  metadata     Json      @default("{}")
  created_at   DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at   DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant              tenants                   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  vendor              vendors                   @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
  location            locations                 @relation(fields: [location_id], references: [id], onDelete: Cascade)
  items               purchase_order_items[]
  inventory_movements inventory_movements[]
  receipts            purchase_order_receipts[]

  @@index([tenant_id], map: "idx_purchase_orders_tenant_id")
  @@index([vendor_id], map: "idx_purchase_orders_vendor_id")
  @@index([status], map: "idx_purchase_orders_status")
}

model purchase_order_items {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchase_order_id String   @db.Uuid
  raw_ingredient_id String   @db.Uuid
  quantity_ordered  Decimal  @db.Decimal(15, 4)
  quantity_received Decimal  @default(0) @db.Decimal(15, 4)
  unit_price        Decimal  @db.Decimal(20, 8)
  total_price       Decimal  @db.Decimal(20, 8)
  created_at        DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at        DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  purchase_order purchase_orders @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)
  raw_ingredient raw_ingredients @relation(fields: [raw_ingredient_id], references: [id], onDelete: Cascade)

  @@unique([purchase_order_id, raw_ingredient_id], map: "idx_po_items_unique")
  @@index([purchase_order_id], map: "idx_po_items_po_id")
  @@index([raw_ingredient_id], map: "idx_po_items_ingredient_id")
}

model purchase_order_receipts {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String   @db.Uuid
  purchase_order_id String   @db.Uuid
  receipt_number    String   @db.VarChar(64) // E.g. REC-001
  notes             String?
  received_at       DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant              tenants               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  purchase_order      purchase_orders       @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)
  inventory_movements inventory_movements[]

  @@index([tenant_id], map: "idx_po_receipts_tenant_id")
  @@index([purchase_order_id], map: "idx_po_receipts_po_id")
}

model product_categories {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  parent_id   String?  @db.Uuid // For nested categories
  name        String   @db.VarChar(255)
  description String?
  status      String   @default("active") @db.VarChar(32) // active, drafted, archived
  created_at  DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at  DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant             tenants              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  parent_category    product_categories?  @relation("CategoryHierarchy", fields: [parent_id], references: [id], onDelete: SetNull)
  child_categories   product_categories[] @relation("CategoryHierarchy")
  products           products[]
  category_modifiers category_modifiers[]

  @@index([tenant_id], map: "idx_categories_tenant_id")
  @@index([parent_id], map: "idx_categories_parent_id")
