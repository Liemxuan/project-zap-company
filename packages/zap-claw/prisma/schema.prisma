model products {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid
  category_id      String?  @db.Uuid
  name             String   @db.VarChar(255)
  description      String?
  is_service       Boolean  @default(false)
  duration_minutes Int? // If service (e.g., Salon)
  status           String   @default("active") @db.VarChar(32) // active, drafted, archived
  metadata         Json     @default("{}") // Sector-specific attributes
  nutritional_info Json? // Toast gap: calories, macros
  allergens        Json? // Toast gap: dietary tags
  prep_station_id  String?  @db.Uuid // Toast gap: KDS routing
  created_at       DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at       DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant           tenants             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  category         product_categories? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  product_variants product_variants[]

  @@index([tenant_id], map: "idx_products_tenant_id")
  @@index([category_id], map: "idx_products_category_id")
  @@index([status], map: "idx_products_status")
}

model product_variants {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid
  product_id       String   @db.Uuid
  name             String   @db.VarChar(255) // e.g., "Small", "Red", "Default"
  sku              String?  @db.VarChar(128)
  barcode          String?  @db.VarChar(128)
  price            Decimal  @default(0) @db.Decimal(20, 8)
  compare_at_price Decimal? @db.Decimal(20, 8)
  inventory_count  Int      @default(0) // Legacy - Deprecated in favor of BOM & Perpetual Ledgers
  is_default       Boolean  @default(false)
  tax_included     Boolean  @default(false) // Toast gap: explicit tax inclusion
  status           String   @default("active") @db.VarChar(32)
  created_at       DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at       DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant           tenants            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  product          products           @relation(fields: [product_id], references: [id], onDelete: Cascade)
  order_items      order_items[]
  linked_modifiers modifier_options[] // Modifiers that point to this variant for inventory deduction
  bom_recipes      bom_recipes[]

  @@unique([tenant_id, sku], map: "idx_variants_tenant_sku")
  @@index([product_id], map: "idx_variants_product_id")
  @@index([status], map: "idx_variants_status")
}

model modifier_lists {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String   @db.Uuid
  name           String   @db.VarChar(255) // e.g., "Dairy Options"
  min_allowed    Int      @default(0)
  max_allowed    Int      @default(1)
  max_per_option Int      @default(1) // Toast gap: multi-select limits on a single option
  status         String   @default("active") @db.VarChar(32)
  created_at     DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at     DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant             tenants              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  modifier_options   modifier_options[]
  category_modifiers category_modifiers[]

  @@index([tenant_id], map: "idx_modifier_lists_tenant_id")
}

model modifier_options {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String   @db.Uuid
  modifier_list_id  String   @db.Uuid
  name              String   @db.VarChar(255) // e.g., "Oat Milk"
  price_override    Decimal? @db.Decimal(20, 8)
  linked_variant_id String?  @db.Uuid // Optional: Deduct inventory from another variant (e.g. "Bacon")
  status            String   @default("active") @db.VarChar(32)
  created_at        DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at        DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant         tenants           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  modifier_list  modifier_lists    @relation(fields: [modifier_list_id], references: [id], onDelete: Cascade)
  linked_variant product_variants? @relation(fields: [linked_variant_id], references: [id], onDelete: SetNull)

  @@index([modifier_list_id], map: "idx_mod_options_list_id")
  @@index([linked_variant_id], map: "idx_mod_options_linked_var_id")
}

model category_modifiers {
  category_id      String @db.Uuid
  modifier_list_id String @db.Uuid

  category      product_categories @relation(fields: [category_id], references: [id], onDelete: Cascade)
  modifier_list modifier_lists     @relation(fields: [modifier_list_id], references: [id], onDelete: Cascade)

  @@id([category_id, modifier_list_id])
}

model menu_presentations {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String   @db.Uuid
  name                  String   @db.VarChar(255) // e.g., "Happy Hour Menu"
  availability_schedule Json? // Toast gap: active_days, active_hours
  metadata              Json     @default("{}") // Visibility rules, active hours, kiosk assignments
  status                String   @default("active") @db.VarChar(32)
  created_at            DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at            DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant tenants @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id], map: "idx_menus_tenant_id")
  @@index([status], map: "idx_menus_status")
}

model pre_modifiers {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  name       String   @db.VarChar(255) // e.g., "Extra", "No", "Side of"
  status     String   @default("active") @db.VarChar(32)
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant tenants @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id], map: "idx_pre_modifiers_tenant_id")
}

model pricing_rules {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  name       String   @db.VarChar(255)
  type       String   @db.VarChar(64) // e.g., "time_based", "promotional"
  metadata   Json     @default("{}") // contains scheduling rules, markup formulas
  status     String   @default("active") @db.VarChar(32)
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant tenants @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id], map: "idx_pricing_rules_tenant_id")
}

model orders {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String  @db.Uuid
  workspace_id String? @db.Uuid
  client_id    String? @db.Uuid

  // COMPARTMENTALIZATION (THE STATIC IDS)
  internal_channel_id    Int? // The internal POS/Kiosk etc origin
  marketplace_channel_id Int  @default(0) // The explicit 0 = Walk-in/Not Applicable fallback rule
  payment_gateway_id     Int? // The payment capture origin

  status        String   @default("pending") @db.VarChar(32) // pending, completed, canceled, refunded
  fulfillment   String   @default("unfulfilled") @db.VarChar(32) // unfulfilled, processing, ready, delivered
  dining_option String   @default("for_here") @db.VarChar(32) // for_here, pickup, delivery, to_go
  subtotal      Decimal  @default(0) @db.Decimal(20, 8)
  tax           Decimal  @default(0) @db.Decimal(20, 8)
  total         Decimal  @default(0) @db.Decimal(20, 8)
  currency      String   @default("USD") @db.Char(3)
  notes         String?
  metadata      Json     @default("{}") // Contextual/external meta, custom attributes
  created_at    DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at    DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant              tenants               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  workspace           workspaces?           @relation(fields: [workspace_id], references: [id], onDelete: SetNull)
  client              clients?              @relation(fields: [client_id], references: [id], onDelete: SetNull)
  internal_channel    internal_channels?    @relation(fields: [internal_channel_id], references: [id], onDelete: NoAction)
  marketplace_channel marketplace_channels  @relation(fields: [marketplace_channel_id], references: [id], onDelete: NoAction)
  payment_gateway     payment_gateways?     @relation(fields: [payment_gateway_id], references: [id], onDelete: NoAction)
  items               order_items[]
  tickets             fulfillment_tickets[]

  @@index([tenant_id], map: "idx_orders_tenant_id")
  @@index([client_id], map: "idx_orders_client_id")
  @@index([status], map: "idx_orders_status")
  @@index([fulfillment], map: "idx_orders_fulfillment")
}

model order_items {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id           String   @db.Uuid
  product_variant_id String?  @db.Uuid // Strictly transact against the variant
  name               String   @db.VarChar(255) // Cached name (Product + Variant)
  quantity           Int      @default(1)
  unit_price         Decimal  @db.Decimal(20, 8)
  total_price        Decimal  @db.Decimal(20, 8)
  metadata           Json     @default("{}") // Store array of purchased modifier_options here
  created_at         DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  order   orders            @relation(fields: [order_id], references: [id], onDelete: Cascade)
  variant product_variants? @relation(fields: [product_variant_id], references: [id], onDelete: SetNull)

  @@index([order_id], map: "idx_order_items_order_id")
  @@index([product_variant_id], map: "idx_order_items_variant_id")
}

model fulfillment_tickets {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  order_id     String    @db.Uuid
  assigned_to  String?   @db.Uuid // user_id
  station      String?   @db.VarChar(64) // e.g., "Grill", "Pick & Pack", "Chair 3"
  status       String    @default("open") @db.VarChar(32) // open, in_progress, completed
  due_at       DateTime? @db.Timestamptz(6)
  completed_at DateTime? @db.Timestamptz(6)
  metadata     Json      @default("{}")
  created_at   DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at   DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant tenants @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  order  orders  @relation(fields: [order_id], references: [id], onDelete: Cascade)
  user   users?  @relation(fields: [assigned_to], references: [id], onDelete: SetNull)

  @@index([tenant_id], map: "idx_fulfillment_tenant_id")
  @@index([order_id], map: "idx_fulfillment_order_id")
  @@index([assigned_to], map: "idx_fulfillment_assigned_to")
  @@index([status], map: "idx_fulfillment_status")
}

model locations {
  id             Int      @id @default(autoincrement())
  tenant_id      String   @db.Uuid
  marketing_name String   @db.VarChar(255) // e.g., Pho24 - Hoan Kiem
  legal_name     String   @db.VarChar(255) // e.g., Pho Twenty Four Hanoi LLC
  status         String   @default("active") @db.VarChar(32)
  created_at     DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at     DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  tenant              tenants               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  inventory_counts    inventory_counts[]
  inventory_movements inventory_movements[]
  purchase_orders     purchase_orders[]

  @@index([tenant_id], map: "idx_locations_tenant_id")
  @@index([status], map: "idx_locations_status")
}
