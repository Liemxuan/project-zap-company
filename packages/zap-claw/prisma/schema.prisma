generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── THE 5 CARDINAL OLYMPUS SECTORS ──
enum IndustrySector {
  FOOD_AND_BEVERAGE // 1. F&B
  BEAUTY_AND_WELLNESS // 2. Spa, Nail, Hair
  HOSPITALITY // 3. Hotels, Airbnb
  COMMERCE // 4. Online/Offline Retail
  PROFESSIONAL_SERVICES // 5. Doctors, Lawyers, CPAs
}

model accounts {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String    @db.Uuid
  wallet_id      String    @db.Uuid
  account_number String    @db.VarChar(64)
  routing_number String?   @db.VarChar(32)
  account_type   String    @db.VarChar(32)
  institution    String?   @db.VarChar(128)
  institution_id String?   @db.VarChar(128)
  external_ref   String?   @db.VarChar(255)
  mask           String?   @db.VarChar(8)
  iban           String?   @db.VarChar(34)
  swift          String?   @db.VarChar(11)
  status         String    @default("active") @db.VarChar(32)
  verified_at    DateTime? @db.Timestamptz(6)
  created_at     DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at     DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  tenants        tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wallets        wallets   @relation(fields: [wallet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenant_id, account_number, institution_id])
  @@index([tenant_id], map: "idx_accounts_merchant_id")
  @@index([status], map: "idx_accounts_status")
  @@index([account_type], map: "idx_accounts_type")
  @@index([wallet_id], map: "idx_accounts_wallet_id")
}

model api_keys {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String    @db.Uuid
  created_by     String?   @db.Uuid
  name           String    @db.VarChar(128)
  key_prefix     String    @db.VarChar(16)
  key_hash       String    @unique
  scopes         String[]  @default([])
  environment    String    @default("live") @db.VarChar(16)
  ip_whitelist   String[]  @default([]) @db.Inet
  rate_limit_rpm Int       @default(1000)
  last_used_at   DateTime? @db.Timestamptz(6)
  expires_at     DateTime? @db.Timestamptz(6)
  status         String    @default("active") @db.VarChar(32)
  created_at     DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at     DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users          users?    @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  tenants        tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([environment], map: "idx_api_keys_environment")
  @@index([expires_at], map: "idx_api_keys_expires_at")
  @@index([key_prefix], map: "idx_api_keys_key_prefix")
  @@index([tenant_id], map: "idx_api_keys_merchant_id")
  @@index([status], map: "idx_api_keys_status")
}

model workspaces {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String       @db.Uuid
  name       String       @db.VarChar(255)
  legal_name String?      @db.VarChar(255)
  tax_id     String?      @db.VarChar(64)
  country    String       @default("US") @db.Char(2)
  currency   String       @default("USD") @db.Char(3)
  address    Json         @default("{}")
  status     String       @default("active") @db.VarChar(32)
  created_at DateTime     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at DateTime     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  tenants    tenants      @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  financials financials[]
  users      users[]
  clients    clients[]
  orders     orders[]

  @@unique([tenant_id, name])
  @@index([tenant_id], map: "idx_companies_merchant_id")
  @@index([status], map: "idx_companies_status")
}

model financials {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String      @db.Uuid
  workspace_id    String?     @db.Uuid
  wallet_id       String?     @db.Uuid
  period_start    DateTime    @db.Date
  period_end      DateTime    @db.Date
  total_income    Decimal     @default(0) @db.Decimal(20, 8)
  total_expenses  Decimal     @default(0) @db.Decimal(20, 8)
  net_cash_flow   Decimal?    @db.Decimal(20, 8)
  opening_balance Decimal     @default(0) @db.Decimal(20, 8)
  closing_balance Decimal     @default(0) @db.Decimal(20, 8)
  currency        String      @default("USD") @db.Char(3)
  notes           String?
  generated_at    DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  created_at      DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  workspaces      workspaces? @relation(fields: [workspace_id], references: [id], onUpdate: NoAction)
  tenants         tenants     @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wallets         wallets?    @relation(fields: [wallet_id], references: [id], onUpdate: NoAction)

  @@unique([tenant_id, wallet_id, period_start, period_end])
  @@index([workspace_id], map: "idx_financials_company_id")
  @@index([tenant_id], map: "idx_financials_merchant_id")
  @@index([period_start, period_end], map: "idx_financials_period")
  @@index([wallet_id], map: "idx_financials_wallet_id")
}

// ── NEW COMPARTMENT 3: FINANCIAL TENDERS ──
model payment_gateways {
  id            Int      @id // STATIC ID INHERITANCE MODEL (1 = Cash, 2 = Square, etc.)
  gateway_name  String   @db.VarChar(128)
  tender_origin String   @db.VarChar(128) // 'Card Present (Terminal)', 'Card Not Present (Web)'
  is_active     Boolean  @default(true) // Inherited global master toggle
  metadata      Json     @default("{}")
  created_at    DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at    DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  orders        orders[]
}

model gateways {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id            String         @db.Uuid
  name                 String         @db.VarChar(128)
  provider             String         @db.VarChar(64)
  environment          String         @default("live") @db.VarChar(16)
  credentials          Json           @default("{}")
  webhook_secret       String?
  webhook_url          String?
  supported_currencies String[]       @default(["USD"])
  supported_methods    String[]       @default([])
  fee_structure        Json           @default("{}")
  priority             Int            @default(1) @db.SmallInt
  is_default           Boolean        @default(false)
  status               String         @default("active") @db.VarChar(32)
  last_health_check    DateTime?      @db.Timestamptz(6)
  health_status        String?        @default("unknown") @db.VarChar(16)
  created_at           DateTime       @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at           DateTime       @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  tenants              tenants        @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transactions         transactions[]

  @@unique([tenant_id, provider, environment])
  @@index([environment], map: "idx_gateways_environment")
  @@index([tenant_id], map: "idx_gateways_merchant_id")
  @@index([tenant_id, priority], map: "idx_gateways_priority")
  @@index([provider], map: "idx_gateways_provider")
  @@index([status], map: "idx_gateways_status")
}

model google_workspaces {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String    @db.Uuid
  customer_id         String    @unique @db.VarChar(64)
  primary_domain      String    @db.VarChar(255)
  admin_email         String    @db.VarChar(255)
  oauth_access_token  String?
  oauth_refresh_token String?
  token_expires_at    DateTime? @db.Timestamptz(6)
  scopes              String[]  @default([])
  edition             String?   @default("Business Starter") @db.VarChar(64)
  seat_count          Int       @default(0)
  verified_domain     Boolean   @default(false)
  sync_enabled        Boolean   @default(true)
  last_synced_at      DateTime? @db.Timestamptz(6)
  status              String    @default("active") @db.VarChar(32)
  metadata            Json      @default("{}")
  created_at          DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at          DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  tenants             tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([customer_id], map: "idx_gws_customer_id")
  @@index([tenant_id], map: "idx_gws_merchant_id")
  @@index([primary_domain], map: "idx_gws_primary_domain")
  @@index([status], map: "idx_gws_status")
}

model tenants {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String                    @db.VarChar(255)
  slug                    String                    @unique @db.VarChar(128)
  email                   String                    @unique @db.VarChar(255)
  phone                   String?                   @db.VarChar(32)
  website                 String?                   @db.VarChar(512)
  logo_url                String?
  industry                String?                   @db.VarChar(128) // Legacy unstructured industry
  sector                  IndustrySector? // The absolute Cardinal Sector mapping
  plan                    String                    @default("starter") @db.VarChar(32)
  status                  String                    @default("active") @db.VarChar(32)
  trial_ends_at           DateTime?                 @db.Timestamptz(6)
  settings                Json                      @default("{}")
  preferred_language      String                    @default("en") @db.VarChar(10) // The Admin UI viewing language
  data_language           String                    @default("en") @db.VarChar(10) // The immutable dataset language established on Day 1
  created_at              DateTime                  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at              DateTime                  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  accounts                accounts[]
  api_keys                api_keys[]
  workspaces              workspaces[]
  financials              financials[]
  gateways                gateways[]
  google_workspaces       google_workspaces[]
  transactions            transactions[]
  user_sessions           user_sessions[]
  users                   users[]
  wallets                 wallets[]
  tenant_subscriptions    tenant_subscriptions[]
  tenant_modules          tenant_modules[]
  products                products[]
  orders                  orders[]
  fulfillment_tickets     fulfillment_tickets[]
  productCategories       product_categories[]
  productVariants         product_variants[]
  modifierLists           modifier_lists[]
  modifierOptions         modifier_options[]
  menuPresentations       menu_presentations[]
  pre_modifiers           pre_modifiers[]
  pricing_rules           pricing_rules[]
  raw_ingredients         raw_ingredients[]
  bom_recipes             bom_recipes[]
  inventory_counts        inventory_counts[]
  inventory_movements     inventory_movements[]
  locations               locations[]
  vendors                 vendors[]
  purchase_orders         purchase_orders[]
  purchase_order_receipts purchase_order_receipts[]

  @@index([plan], map: "idx_merchants_plan")
  @@index([slug], map: "idx_merchants_slug")
  @@index([status], map: "idx_merchants_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model transactions {
  id                                           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                                    String    @db.Uuid
  initiated_by                                 String?   @db.Uuid
  from_wallet_id                               String?   @db.Uuid
  to_wallet_id                                 String?   @db.Uuid
  type                                         String    @db.VarChar(32)
  category                                     String?   @db.VarChar(64)
  amount                                       Decimal   @db.Decimal(20, 8)
  currency                                     String    @default("USD") @db.Char(3)
  exchange_rate                                Decimal   @default(1) @db.Decimal(18, 8)
  fee                                          Decimal   @default(0) @db.Decimal(20, 8)
  description                                  String?
  reference                                    String?   @db.VarChar(255)
  gateway_id                                   String?   @db.Uuid
  status                                       String    @default("pending") @db.VarChar(32)
  metadata                                     Json      @default("{}")
  executed_at                                  DateTime? @db.Timestamptz(6)
  created_at                                   DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at                                   DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  gateways                                     gateways? @relation(fields: [gateway_id], references: [id], onUpdate: NoAction, map: "fk_transactions_gateway")
  wallets_transactions_from_wallet_idTowallets wallets?  @relation("transactions_from_wallet_idTowallets", fields: [from_wallet_id], references: [id], onUpdate: NoAction)
  users                                        users?    @relation(fields: [initiated_by], references: [id], onUpdate: NoAction)
  tenants                                      tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wallets_transactions_to_wallet_idTowallets   wallets?  @relation("transactions_to_wallet_idTowallets", fields: [to_wallet_id], references: [id], onUpdate: NoAction)

  @@index([executed_at(sort: Desc)], map: "idx_transactions_executed_at")
  @@index([from_wallet_id], map: "idx_transactions_from_wallet")
  @@index([gateway_id], map: "idx_transactions_gateway_id")
  @@index([initiated_by], map: "idx_transactions_initiated_by")
  @@index([tenant_id], map: "idx_transactions_merchant_id")
  @@index([metadata], map: "idx_transactions_metadata", type: Gin)
  @@index([status], map: "idx_transactions_status")
  @@index([to_wallet_id], map: "idx_transactions_to_wallet")
  @@index([type], map: "idx_transactions_type")
}

model user_sessions {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String    @db.Uuid
  user_id            String    @db.Uuid
  token_hash         String    @unique
  ip_address         String    @db.Inet
  user_agent         String?
  device_type        String?   @db.VarChar(32)
  device_name        String?   @db.VarChar(128)
  device_fingerprint String?
  browser            String?   @db.VarChar(64)
  os                 String?   @db.VarChar(64)
  country            String?   @db.Char(2)
  cookies            Json      @default("{}")
  is_active          Boolean   @default(true)
  revoked_at         DateTime? @db.Timestamptz(6)
  revoked_reason     String?   @db.VarChar(128)
  expires_at         DateTime  @db.Timestamptz(6)
  created_at         DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at         DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  tenants            tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_emp_sessions_expires_at")
  @@index([ip_address], map: "idx_emp_sessions_ip")
  @@index([is_active], map: "idx_emp_sessions_is_active")
  @@index([tenant_id], map: "idx_emp_sessions_merchant_id")
  @@index([token_hash], map: "idx_emp_sessions_token_hash")
  @@index([user_id], map: "idx_emp_sessions_employee_id")
}

model users {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String                @db.Uuid
  workspace_id        String                @db.Uuid
  username            String                @db.VarChar(64)
  email               String                @db.VarChar(255)
  password_hash       String
  passcode            String?               @db.VarChar(16)
  display_name        String?               @db.VarChar(128)
  avatar_url          String?
  role                String                @default("user") @db.VarChar(32)
  position            String?               @db.VarChar(128)
  department          String?               @db.VarChar(128)
  status              String                @default("active") @db.VarChar(32)
  preferred_language  String                @default("en") @db.VarChar(10) // The User's UI viewing language
  restrictions        String[]              @default([])
  byok_key            String?               @db.VarChar(255)
  companion_id        String?               @db.VarChar(128)
  verified_at         DateTime?             @db.Timestamptz(6)
  last_login_at       DateTime?             @db.Timestamptz(6)
  metadata            Json                  @default("{}")
  created_at          DateTime              @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at          DateTime              @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  api_keys            api_keys[]
  transactions        transactions[]
  user_sessions       user_sessions[]
  workspaces          workspaces            @relation(fields: [workspace_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants             tenants               @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user_interactions   user_interactions[]
  fulfillment_tickets fulfillment_tickets[]

  @@unique([tenant_id, email])
  @@unique([tenant_id, username])
  @@index([workspace_id], map: "idx_employees_company_id")
  @@index([email], map: "idx_employees_email")
  @@index([tenant_id], map: "idx_employees_merchant_id")
  @@index([role], map: "idx_employees_role")
  @@index([status], map: "idx_employees_status")
  @@index([username], map: "idx_employees_username")
}

model system_admins {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username        String    @unique @db.VarChar(64)
  email           String    @unique @db.VarChar(255)
  password_hash   String
  display_name    String?   @db.VarChar(128)
  role            String    @default("agent") @db.VarChar(32) // e.g. "super_admin", "agent", "staff"
  position        String?   @db.VarChar(128)
  level           Int       @default(1)
  status          String    @default("active") @db.VarChar(32)
  restrictions    String[]  @default([])
  byok_key        String?   @db.VarChar(255)
  companion_id    String?   @db.VarChar(128)
  omni_router_ext Boolean   @default(false)
  last_login_at   DateTime? @db.Timestamptz(6)
  metadata        Json      @default("{}")
  created_at      DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at      DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  @@index([role], map: "idx_oly_emp_role")
  @@index([status], map: "idx_oly_emp_status")
}

// ── EXPERTISE-AS-A-SERVICE (GStack Personas) ──

model ai_personas {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String                 @unique @db.VarChar(128) // e.g. "ceo-plan-audit" 
  display_name         String                 @db.VarChar(128)
  system_prompt        String                 @db.Text
  capabilities         Json                   @default("[]") // e.g. ["read_code", "run_tests"]
  sector               IndustrySector? // Null = Universal Persona. Assigned = Sector Specific Expert
  tier                 String                 @default("basic") @db.VarChar(32) // basic, premium, enterprise
  status               String                 @default("active") @db.VarChar(32)
  created_at           DateTime               @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at           DateTime               @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  tenant_subscriptions tenant_subscriptions[]
  user_interactions    user_interactions[]

  @@index([name], map: "idx_ai_personas_name")
  @@index([tier], map: "idx_ai_personas_tier")
  @@index([status], map: "idx_ai_personas_status")
}

model tenant_subscriptions {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String      @db.Uuid
  persona_id    String      @db.Uuid
  status        String      @default("active") @db.VarChar(32) // active, suspended, canceled
  billing_cycle String      @default("monthly") @db.VarChar(32)
  purchased_at  DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  expires_at    DateTime?   @db.Timestamptz(6)
  created_at    DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at    DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  tenants       tenants     @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ai_personas   ai_personas @relation(fields: [persona_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenant_id, persona_id])
  @@index([tenant_id], map: "idx_merchant_subs_merchant_id")
  @@index([persona_id], map: "idx_merchant_subs_persona_id")
  @@index([status], map: "idx_merchant_subs_status")
}

model user_interactions {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String      @db.Uuid
  workspace_id     String      @db.Uuid
  persona_id       String      @db.Uuid
  session_context  Json        @default("{}") // Log of chat/review
  tokens_used      Int         @default(0)
  interaction_date DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  created_at       DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at       DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users            users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ai_personas      ai_personas @relation(fields: [persona_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_emp_interactions_emp_id")
  @@index([workspace_id], map: "idx_emp_interactions_company_id")
  @@index([persona_id], map: "idx_emp_interactions_persona_id")
}

model clients {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String      @db.Uuid
  workspace_id    String?     @db.Uuid
  name            String      @db.VarChar(255)
  phone           String?     @db.VarChar(32)
  email           String?     @db.VarChar(255)
  loyalty_points  Int         @default(0)
  preferences     Json        @default("{}")
  status          String      @default("active") @db.VarChar(32)
  last_visited_at DateTime?   @db.Timestamptz(6)
  created_at      DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at      DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  workspaces      workspaces? @relation(fields: [workspace_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  orders          orders[]

  @@unique([tenant_id, phone])
