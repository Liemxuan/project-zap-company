{
    "name": "zap-claw",
    "version": "1.0.0",
    "description": "Lean, secure personal AI agent — Telegram + OpenRouter",
    "type": "module",
    "scripts": {
        "dev": "cross-env PORT=3900 tsx watch src/server.ts",
        "gateway": "cross-env PORT=3900 tsx watch src/server.ts",
        "daemon": "cross-env PORT=8000 tsx watch src/index.ts",
        "jerry": "tsx src/jerry_server.ts",
        "spike": "tsx src/spike_server.ts",
        "tommy": "cross-env AGENT_NAME=Tommy AGENT_TOKEN_VAR=TELEGRAM_BOT_TOKEN_TOMMY tsx src/generic_agent.ts",
        "athena": "tsx src/athena_server.ts",
        "hermes": "cross-env AGENT_NAME=Hermes AGENT_TOKEN_VAR=TELEGRAM_BOT_TOKEN_HERMES tsx src/generic_agent.ts",
        "hawk": "cross-env AGENT_NAME=Hawk AGENT_TOKEN_VAR=TELEGRAM_BOT_TOKEN_HAWK tsx src/generic_agent.ts",
        "nova": "cross-env AGENT_NAME=Nova AGENT_TOKEN_VAR=TELEGRAM_BOT_TOKEN_NOVA tsx src/generic_agent.ts",
        "raven": "cross-env AGENT_NAME=Raven AGENT_TOKEN_VAR=TELEGRAM_BOT_TOKEN_RAVEN tsx src/generic_agent.ts",
        "scout": "cross-env AGENT_NAME=Scout AGENT_TOKEN_VAR=TELEGRAM_BOT_TOKEN_SCOUT tsx src/generic_agent.ts",
        "coder": "cross-env AGENT_NAME=Coder AGENT_TOKEN_VAR=TELEGRAM_BOT_TOKEN_CODER AGENT_FLAVOR=tier_1_coder tsx src/generic_agent.ts",
        "cleo": "cross-env AGENT_NAME=Cleo AGENT_TOKEN_VAR=TELEGRAM_BOT_TOKEN_CLEO AGENT_FLAVOR=tier_2_ops tsx src/generic_agent.ts",
        "antigravity": "cross-env AGENT_NAME=Antigravity AGENT_TOKEN_VAR=TELEGRAM_BOT_TOKEN tsx src/generic_agent.ts",
        "health": "tsx src/scripts/measure_health.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "generate": "prisma generate",
        "audit": "tsx src/scripts/audit.ts",
        "backup:db": "tsx scripts/backup_postgres_to_mongo.ts"
    },
    "dependencies": {
        "@google/genai": "^1.44.0",
        "@langchain/community": "^1.1.23",
        "@langchain/core": "^1.1.32",
        "@langchain/google-genai": "^2.1.25",
        "@langchain/openai": "^1.2.13",
        "@modelcontextprotocol/sdk": "^1.27.1",
        "@prisma/client": "^6.19.2",
        "@types/cors": "^2.8.19",
        "@types/morgan": "^1.9.10",
        "better-sqlite3": "^12.6.2",
        "body-parser": "^2.2.2",
        "chromadb": "^3.3.3",
        "cors": "^2.8.6",
        "cross-env": "^10.1.0",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "grammy": "^1.40.1",
        "handlebars": "^4.7.9",
        "ioredis": "^5.10.0",
        "mongodb": "^7.1.0",
        "mongoose": "^9.3.3",
        "morgan": "^1.10.1",
        "openai": "^6.25.0",
        "stripe": "^20.4.1",
        "ts-morph": "^27.0.2",
        "ws": "^8.18.0",
        "zod": "^3.25.76",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/body-parser": "^1.19.6",
        "@types/express": "^5.0.6",
        "@types/handlebars": "^4.1.0",
        "@types/jest": "^30.0.0",
        "@types/mongoose": "^5.11.97",
        "@types/node": "^25.3.2",
        "@types/ws": "^8.5.10",
        "jest": "^30.3.0",
        "prisma": "^6.19.2",
        "ts-jest": "^29.4.6",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}