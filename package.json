{
    "name": "olympus-monorepo",
    "private": true,
    "packageManager": "pnpm@9.15.4",
    "scripts": {
        "clean:pipe": "rm -rf .bash_history 2>/dev/null || true",
        "purge:locks": "pnpm store prune || true",
        "prebuild": "pnpm run clean:pipe",
        "verify": "pnpm run prebuild && pnpm run build",
        "dev": "pnpm run -r --parallel dev",
        "build": "turbo run build --log-order=stream",
        "lint": "turbo run lint --log-order=stream",
        "reset-dev": "bash .agent/skills/devops-server-reset/reset-dev.sh"
    },
    "devDependencies": {
        "cross-env": "^10.1.0",
        "prisma": "^6.19.2",
        "puppeteer": "^24.40.0",
        "tsx": "^4.21.0",
        "turbo": "^2.9.3"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@prisma/client": "^6.19.2",
        "mongodb": "^7.1.1",
        "react-hook-form": "^7.72.0",
        "zod": "^3.25.76",
        "zustand": "^5.0.12"
    },
